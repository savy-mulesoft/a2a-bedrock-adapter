# Copy to config.properties and fill in values. config.properties is gitignored.

http.listener.port=8082
a2a.listener.port=8081

agent.host.name=localhost
agent.host.protocol=http
agent.host=${agent.host.protocol}://${agent.host.name}:${a2a.listener.port}
agent.path=/compliance-bedrock-agent

agent.name=Bedrock Tax & Compliance Agent
agent.version=1.0.0
agent.description=Evaluates financial trades and portfolio strategies against Canadian tax laws and financial instrument regulations.

agent.skill.1.id=1
agent.skill.1.name=Canadian Financial Compliance Check
agent.skill.1.description=Verifies regulatory compliance, assesses tax implications, and evaluates legal constraints for trading various Canadian financial instruments.
agent.skill.1.tags=["compliance", "tax", "legal", "financial-instruments", "regulations"]

aws.region=us-east-2
aws.service.signing.name=bedrock
aws.accessKey=YOUR_ACCESS_KEY_ID
aws.secretKey=YOUR_SECRET_ACCESS_KEY
aws.sessionToken=
aws.agent.id=YOUR_BEDROCK_AGENT_ID
aws.alias.id=YOUR_AGENT_ALIAS_ID
